<odoo>
    <data noupdate="1">
        <record id="memory_rag_cron" model="ir.cron">
            <field name="name">Memory RAG Cron</field>
            <field name="model_id" ref="model_ai_memory"/>
            <field name="state">code</field>
            <field name="code">model.cron_rag()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name='interval_number'>1</field>
            <field name='interval_type'>hours</field>
            <!-- #if VERSION == "16" -->
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <!-- #endif -->
        </record>
    </data>
</odoo>
