<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="demo_mock_product_template" model="product.template">
            <field name="name">Demo Mock</field>
            <field name="is_llm" eval="True"/>
            <field name="llm_library">odoo.addons.ai_agent.mock.demo_llm</field>
            <field name="llm_type">DemoChatLLM</field>
            <field name="llm_etype">DemoEmbeddings</field>
            <field name="llm_elibrary">odoo.addons.ai_agent.mock.demo_llm</field>
            <field name="fallback_api_key_name">demo_mock_api_key</field>
            <field name="llm_price_url">https://platform.openai.com/docs/guides/error-codes/api-errors</field>
        </record>

        <record id="demo_mock_attribute_value_chat" model="product.attribute.value">
            <field name="name">demo-gpt</field>
            <field name="attribute_id" ref="ai_agent.product_attribute_model"/>
            <field name="is_key_required" eval="False"/>
            <field name="has_temperature" eval="True"/>
            <field name="tpm">1000000</field>
            <field name="rpm">10000</field>
            <field name="context_window">128000</field>
        </record>

        <record id="demo_mock_attribute_value_embed" model="product.attribute.value">
            <field name="name">demo-embed</field>
            <field name="attribute_id" ref="ai_agent.product_attribute_model"/>
            <field name="is_embedded" eval="True"/>
            <field name="is_key_required" eval="False"/>
            <field name="tpm">1000000</field>
            <field name="rpm">10000</field>
        </record>

        <record id="demo_mock_template_attribute_line_model" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="demo_mock_product_template"/>
            <field name="attribute_id" ref="product_attribute_model"/>
            <field name="value_ids" eval="[(6, 0, [
                ref('demo_mock_attribute_value_chat'),
                ref('demo_mock_attribute_value_embed'),
            ])]"/>
        </record>

        <record id="demo_mock_template_attribute_line_data_type" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="demo_mock_product_template"/>
            <field name="attribute_id" ref="product_attribute_data_type"/>
            <field name="value_ids" eval="[(6, 0, [ref('product_attribute_value_text')])]"/>
        </record>

        <record id="demo_mock_template_attribute_line_token_type" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="demo_mock_product_template"/>
            <field name="attribute_id" ref="product_attribute_token_type"/>
            <field name="value_ids" eval="[(6, 0, [
                ref('product_attribute_value_input_tokens'),
                ref('product_attribute_value_output_tokens'),
            ])]"/>
        </record>

    </data>
</odoo>
