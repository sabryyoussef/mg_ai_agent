<odoo>

    <record id="ai_quest_session_message_list" model="ir.ui.view">
        <field name="name">ai.quest.session.message.list</field>
        <field name="model">ai.quest.session.message</field>
        <field name="arch" type="xml">
            <!-- #if VERSION >= "18.0" -->
            <list string="Messages">
                <field name="sequence"/>
<!--
                <field name="ai_quest_session_id"/>
-->
                <field name="date"/>
                <field name="message_type"/>
                <field name="message_content"/>
                <field name="message" optional="hide"/>
                <field name="message_raw" optional="hide"/>
                <field name="time_difference_ms" optional="hide"/>
            </list>
            <!-- #elif VERSION <= "17.0" -->
            <tree string="Messages">
                <field name="sequence"/>
<!--
                <field name="ai_quest_session_id"/>
-->
                <field name="date"/>
                <field name="message_type"/>
                <field name="message_content"/>
                <field name="message" optional="hide"/>
                <field name="message_raw" optional="hide"/>
                <field name="time_difference_ms" optional="hide"/>
            </tree>
            <!-- #endif -->
        </field>
    </record>

    <record id="ai_quest_session_message_search" model="ir.ui.view">
        <field name="name">ai.quest.session.message.search</field>
        <field name="model">ai.quest.session.message</field>
        <field name="arch" type="xml">
            <search string="Search Message">
                <field name="message_content" />
                <field name="message_type"/>
                <field name="message_raw"/>
                <group expand="0" string="Group By">
                    <filter string="Message Type" name="group_by_message_type" context="{'group_by': 'message_type'}"/>
                </group>
                <separator/>
            </search>
        </field>
    </record>

    <record id="ai_quest_session_message_form" model="ir.ui.view">
        <field name="name">ai.quest.session.message.form</field>
        <field name="model">ai.quest.session.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet string="Message">
                    <group>
                        <group>
<!--
                            <field name="ai_quest_session_id"/>
-->
                            <field name="date"/>
                            <field name="time_difference_ms"/>
                            <field name="message_type"/>
                            <field name="message_content"/>
                        </group>
    
                    </group>
<notebook>
<page string="Content" name="content">
            <field name="message" nolabel="1"/>
</page>
<page string="Html Content" name="raw">
            <field name="message_html" nolabel="1"/>
</page>
<page string="Raw Content" name="raw">
            <field name="message_raw" nolabel="1"/>
</page>
<page string="Traceback" name="trace">
            <field name="traceback" nolabel="1"/>
</page>
</notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_ai_quest_session_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">ai.quest.session.message</field>
        <!-- #if VERSION >= "18.0" -->
        <field name="view_mode">list,form</field>
        <!-- #elif VERSION <= "17.0" -->
        <field name="view_mode">tree,form</field>
        <!-- #endif -->
    </record>

    <menuitem id="ai_agent.menu_ai_quest_session_message" name="Messages" parent="ai_agent.menu_ai_agent_configuration" action="action_ai_quest_session_message"/>

</odoo>
